{
  "name": "voxa",
  "version": "0.1.0",
  "description": "AI Conversation Intelligence Platform",
  "license": "MIT",
  "author": "Luiz Neto",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luizvb/voxa.git"
  },
  "bugs": {
    "url": "https://github.com/luizvb/voxa/issues"
  },
  "homepage": "https://github.com/luizvb/voxa#readme",
  "keywords": [
    "electron",
    "go",
    "macos",
    "audio",
    "recorder",
    "system-audio",
    "voice-recording"
  ],
  "main": "app/main.js",
  "scripts": {
    "build:go": "go build -o bin/recorderd ./cmd/recorderd",
    "build:sidecar:mac": "node scripts/build-sidecar.mjs mac",
    "build:sidecar:win": "node scripts/build-sidecar.mjs win",
    "dev:vite": "vite --port 5173 --strictPort",
    "dev:electron": "cross-env NODE_ENV=development electron .",
    "dev": "npm run build:go && concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "build:react": "vite build",
    "build:all": "npm run build:go && npm run build:react",
    "release": "node scripts/build-release.mjs current",
    "release:mac": "node scripts/build-release.mjs mac",
    "release:win": "node scripts/build-release.mjs win",
    "release:all": "node scripts/build-release.mjs all",
    "release:publish": "node scripts/publish-release.mjs",
    "vercel:env:sync": "node scripts/sync-vercel-env.mjs",
    "test": "node --test test/*.test.js",
    "test:go": "go test ./...",
    "test:all": "npm run test:go && npm test"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^7.0.2",
    "vite": "^8.1.4"
  },
  "build": {
    "appId": "com.luizneto.voxa",
    "productName": "Voxa",
    "asar": true,
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "release-assets/blob-client.cjs",
        "to": "blob-client.cjs"
      }
    ],
    "files": [
      "app/**/*",
      "dist/**/*",
      "package.json",
      "!node_modules/**/*"
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "extraResources": [
        {
          "from": "release-assets/macos/recorderd",
          "to": "recorderd"
        }
      ],
      "extendInfo": {
        "NSMicrophoneUsageDescription": "This app records your microphone when you start a recording.",
        "NSAudioCaptureUsageDescription": "This app records system audio so both sides of a call can be captured."
      }
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "extraResources": [
        {
          "from": "release-assets/windows/recorderd.exe",
          "to": "recorderd.exe"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "@neondatabase/auth-ui": "^0.2.1-beta",
    "@neondatabase/neon-js": "^0.6.2-beta",
    "@radix-ui/react-avatar": "^1.2.2",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.3",
    "@vercel/blob": "^2.6.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.24.0",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0"
  }
}
